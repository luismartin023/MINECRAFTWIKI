<Window x:Class="MINECRAFTWIKI.VIEW.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MINECRAFTWIKI.VIEWMODEL"
        Title="Minecraft Wiki WPF" Height="650" Width="1000">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Background>
        <!-- Fondo de textura de Minecraft con mosaico -->
        <ImageBrush ImageSource="pack://application:,,,/Assets/background.png" TileMode="Tile" Viewport="0,0,128,128" ViewportUnits="Absolute" Stretch="UniformToFill" />
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Capa semitransparente para oscurecer el fondo y poder leer -->
        <Rectangle Fill="#D0000000" Grid.ColumnSpan="2"/>

        <!-- PANEL IZQUIERDO: LISTA -->
        <Border Grid.Column="0" Background="#90111111" BorderBrush="#444444" BorderThickness="0,0,4,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20">
                    <Image Source="pack://application:,,,/Assets/logo.png" Height="80" Margin="0,0,0,10" RenderOptions.BitmapScalingMode="NearestNeighbor" />
                    <TextBlock Text="WPF MVVM WIKI" FontFamily="pack://application:,,,/Assets/#Press Start 2P" FontSize="14" Foreground="#AAAAAA" TextAlignment="Center" />
                </StackPanel>

                <!-- El ListBox se enlaza a Entities y a SelectedEntity -->
                <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="10,0,10,10" 
                         ItemsSource="{Binding Entities}" 
                         SelectedItem="{Binding SelectedEntity}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <!-- Cuadro estilo inventario -->
                                <Border Grid.Column="0" Width="48" Height="48" Background="#8B8B8B" BorderBrush="#373737" BorderThickness="2" CornerRadius="2">
                                    <Border BorderBrush="#FFFFFF" BorderThickness="2,2,0,0" CornerRadius="2">
                                        <Image Source="{Binding Image}" Width="32" Height="32" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    </Border>
                                </Border>

                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontFamily="pack://application:,,,/Assets/#Press Start 2P" FontSize="12" Foreground="White" VerticalAlignment="Center" Margin="15,0,0,0" TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#44FFFFFF" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#22FFFFFF" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!-- PANEL DERECHO: DETALLES -->
        <Grid Grid.Column="1" Margin="40" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedEntity}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Hidden"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Foto -->
            <Border Grid.Row="0" Width="160" Height="160" Background="#8B8B8B" BorderBrush="#373737" BorderThickness="4" HorizontalAlignment="Center" Margin="0,20,0,20" CornerRadius="4">
                <Border BorderBrush="#FFFFFF" BorderThickness="4,4,0,0" CornerRadius="2">
                    <Image Source="{Binding SelectedEntity.Image}" RenderOptions.BitmapScalingMode="NearestNeighbor" Margin="10"/>
                </Border>
            </Border>

            <!-- Textos enlazados -->
            <TextBlock Grid.Row="1" Text="{Binding SelectedEntity.Name}" FontFamily="pack://application:,,,/Assets/#Press Start 2P" FontSize="28" Foreground="#FFAA00" HorizontalAlignment="Center" Margin="0,0,0,15">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="0" ShadowDepth="4" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
                <Border Background="#222222" BorderBrush="#555555" BorderThickness="2" CornerRadius="0" Padding="10,6" Margin="0,0,15,0">
                    <TextBlock Text="{Binding SelectedEntity.Category}" FontFamily="pack://application:,,,/Assets/#Press Start 2P" Foreground="#55FFFF" FontSize="12"/>
                </Border>
                <Border Background="#222222" BorderBrush="#555555" BorderThickness="2" CornerRadius="0" Padding="10,6">
                    <TextBlock Text="{Binding SelectedEntity.Type}" FontFamily="pack://application:,,,/Assets/#Press Start 2P" Foreground="#55FF55" FontSize="12"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="3" MaxWidth="500">
                <TextBlock Text="ESTADÍSTICAS" FontFamily="pack://application:,,,/Assets/#Press Start 2P" FontSize="14" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding SelectedEntity.Health}" FontFamily="pack://application:,,,/Assets/#Press Start 2P" FontSize="14" Foreground="#FF5555" Margin="0,0,0,30"/>

                <TextBlock Text="DESCRIPCIÓN" FontFamily="pack://application:,,,/Assets/#Press Start 2P" FontSize="14" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding SelectedEntity.Description}" FontFamily="pack://application:,,,/Assets/#Press Start 2P" FontSize="12" Foreground="White" TextWrapping="Wrap" LineHeight="20"/>
            </StackPanel>
        </Grid>

        <!-- Mensaje cuando no hay nada seleccionado -->
        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Hidden"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedEntity}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            
            <Image Source="pack://application:,,,/Assets/logo.png" Height="60" Margin="0,0,0,20" Opacity="0.5" RenderOptions.BitmapScalingMode="NearestNeighbor" />
            <TextBlock Text="SELECCIONA UN ÍTEM" FontFamily="pack://application:,,,/Assets/#Press Start 2P" FontSize="16" Foreground="#555555" TextAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
